#!/bin/sh
set -e

case "$1" in
    remove|purge)
        # Kill any running instances
        pkill -f "clipboard_manager" 2>/dev/null || true

        # Remove autostart entry for all users
        getent passwd | awk -F: '$3 >= 1000 && $6 ~ /^\/home/ { print $6 }' | while read home; do
            rm -f "$home/.config/autostart/clipboard-manager.desktop"
        done
        ;;
esac

#DEBHELPER#
